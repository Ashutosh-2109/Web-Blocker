{
  "manifest_version": 3,
  "name": "FocusBlock",
  "version": "1.0",
  "description": "Block distracting websites for a set time limit with a beautiful UI.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [{
    "resources": ["blocked.html", "blocked.css", "blocked.js"],
    "matches": ["<all_urls>"]
  }]
}
